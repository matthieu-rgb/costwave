# Costwave Production Environment Variables
# Copy this file to .env.production and fill in the values

# ===== APPLICATION =====
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://costwave.app
BETTER_AUTH_URL=https://costwave.app

# ===== DATABASE =====
# Docker internal connection (postgres is the service name in docker-compose.prod.yml)
DATABASE_URL=postgres://costwave:CHANGE_ME@postgres:5432/costwave

# Database password (used by both Postgres and Costwave)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ===== AUTH (generate with: openssl rand -base64 32) =====
# Already generated - DO NOT REGENERATE (user's existing values)
BETTER_AUTH_SECRET=
ENCRYPTION_PEPPER=

# ===== STRIPE (DISABLED FOR V1) =====
# Leave empty to disable Stripe features in production
# Will be configured in V2 when payment system is ready
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=

# ===== EMAIL (Resend) =====
RESEND_API_KEY=
EMAIL_FROM=Costwave <noreply@costwave.app>

# ===== PUSH NOTIFICATIONS =====
# Already generated - DO NOT REGENERATE (user's existing values)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@costwave.app

# ===== REDIS =====
# Generate with: openssl rand -base64 32
REDIS_AUTH=CHANGE_ME

# ===== LANGFUSE (DISABLED FOR V1) =====
# Leave empty to disable Langfuse tracking in production
# Code remains but service is not deployed
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
