# Costwave Production Environment Variables
# Copy this file to .env.production and fill in the values

# ===== APPLICATION =====
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://costwave.app
BETTER_AUTH_URL=https://costwave.app

# ===== DATABASE =====
# Format: postgres://user:password@host:port/database
DATABASE_URL=

# ===== AUTH (generate with: openssl rand -base64 32) =====
BETTER_AUTH_SECRET=
ENCRYPTION_PEPPER=

# ===== STRIPE (LIVE MODE - generate from Stripe Dashboard) =====
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=

# ===== EMAIL (Resend) =====
RESEND_API_KEY=
EMAIL_FROM=Costwave <noreply@costwave.app>

# ===== PUSH NOTIFICATIONS (generate with: npx web-push generate-vapid-keys) =====
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@costwave.app

# ===== LANGFUSE (production project - separate from dev) =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://langfuse.costwave.app

# ===== STORAGE (MinIO or S3) =====
# Optional - if using MinIO/S3 for backups or assets
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET=
